# Model provider configuration
# Default setup: local model served by Ollama, accessed through LiteLLM.
MODEL_NAME=ollama_chat/llama3.2
OLLAMA_API_BASE=http://localhost:11434

# Optional: only needed if using an alternative LiteLLM-compatible provider
# instead of the local Ollama model.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
